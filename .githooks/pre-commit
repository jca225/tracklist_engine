#!/bin/bash
# Pre-commit guardrails. One-time setup per clone:
#   git config core.hooksPath .githooks
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

PYTHON="${ROOT}/venvs/audio/bin/python"
if [[ ! -x "$PYTHON" ]]; then
  PYTHON=python3
fi

"$PYTHON" scripts/guardrails.py

if [[ "${GUARDRAILS_FULL:-}" == "1" ]]; then
  "$PYTHON" -m pytest \
    tests/test_repo_root_paths.py \
    tests/test_identity_axes.py \
    tests/test_recording_axes.py \
    tests/test_essentia_adapter.py -q
fi
